{
  "name": "notez-monorepo",
  "private": true,
  "description": "NoteZ - desktop app, marketing site, and shared packages.",
  "type": "module",
  "scripts": {
    "desktop:dev": "pnpm --filter @notez/desktop dev",
    "desktop:tauri:dev": "pnpm --filter @notez/desktop tauri:dev",
    "desktop:build": "pnpm --filter @notez/desktop build",
    "desktop:tauri:build": "pnpm --filter @notez/desktop tauri:build",
    "desktop:typecheck": "pnpm --filter @notez/desktop typecheck",
    "desktop:test": "pnpm --filter @notez/desktop test",
    "web:dev": "pnpm --filter @notez/web dev",
    "web:build": "pnpm --filter @notez/web build",
    "web:preview": "pnpm --filter @notez/web preview",
    "lint": "biome check apps packages",
    "lint:fix": "biome check --write apps packages",
    "format": "biome format --write apps packages",
    "typecheck": "pnpm -r --parallel typecheck"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "1.9.4"
  }
}
