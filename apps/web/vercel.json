{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm --filter @notez/web build",
  "outputDirectory": "dist",
  "installCommand": "echo 'install handled in buildCommand'",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./ ../../packages/shared ../../pnpm-lock.yaml ../../pnpm-workspace.yaml"
}
