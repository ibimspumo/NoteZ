---
import { DESKTOP_VERSION, DOWNLOAD_URL, SOURCE_URL } from "../data/site";
import Icon from "./icons.astro";
---

<section class="nz-hero" id="top">
  <div class="nz-orb"></div>
  <div class="nz-container" style="position: relative; z-index: 1;">
    <div class="nz-logo-xl">
      <img src="/notez-logo.svg" alt="NoteZ" style="width: 56px; height: 64px;" />
    </div>
    <div style="margin-top: 28px;">
      <span class="nz-eyebrow">
        <span class="dot"></span>
        v{DESKTOP_VERSION} · for desktop · macOS first, Windows + Linux next
      </span>
    </div>
    <h1 class="nz-h1">
      The fastest<br />notes on your <span class="grad">desktop</span>.
    </h1>
    <p class="nz-sub">
      The fastest note app on your desktop. A million notes, found before you
      finish typing. Open the app and it's already there - no spinner, no
      sign-in, no waiting. Your notes stay on your machine. That's the whole
      pitch.
    </p>
    <div class="nz-cta-row">
      <a class="nz-btn nz-btn-primary" href={DOWNLOAD_URL}>
        <Icon name="download" />
        Download for desktop<span class="nz-btn-meta">· free</span>
      </a>
      <a class="nz-btn nz-btn-ghost" href={SOURCE_URL}>
        <Icon name="github" /> View source
      </a>
    </div>
    <div class="nz-meta-strip">
      <span><span class="pip"></span> No account</span>
      <span><span class="pip"></span> No telemetry</span>
      <span><span class="pip"></span> Works offline</span>
      <span><span class="pip"></span> Free forever</span>
    </div>
  </div>
</section>
