---
import {
  DESKTOP_VERSION,
  DOWNLOAD_URL,
  SOURCE_URL,
  ISSUES_URL,
  LICENSE_URL,
} from "../data/site";

const year = new Date().getFullYear();
---

<footer class="nz-footer">
  <div class="nz-container">
    <div class="nz-footer-row">
      <div>
        <div class="nz-footer-brand">
          <img src="/notez-logo.svg" alt="" />
          <span>NoteZ</span>
        </div>
        <div style="margin-top: 10px; max-width: 280px;">
          Fast, local, beautiful notes for your desktop. Built by one person on
          the side, in the open.
        </div>
      </div>
      <div class="nz-footer-cols">
        <div class="nz-footer-col">
          <h4>Product</h4>
          <a href="#performance">Performance</a>
          <a href="#features">Features</a>
          <a href="#faq">FAQ</a>
        </div>
        <div class="nz-footer-col">
          <h4>Source</h4>
          <a href={SOURCE_URL}>GitHub</a>
          <a href={DOWNLOAD_URL}>Releases</a>
          <a href={ISSUES_URL}>Issues</a>
        </div>
        <div class="nz-footer-col">
          <h4>Legal</h4>
          <a href={LICENSE_URL}>License</a>
          <a href="/impressum">Imprint</a>
        </div>
      </div>
    </div>
    <div class="nz-footer-bot">
      <span>&copy; {year} NoteZ. No accounts, no servers, no tracking.</span>
      <span>Built in Berlin · v{DESKTOP_VERSION}</span>
    </div>
  </div>
</footer>
