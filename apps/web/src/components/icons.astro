---
// Inline SVG glyphs ported 1:1 from landing-sections.jsx (G object).
// Stroke-based, currentColor, sized via the parent's font-size where it
// matters. Kept in one file so the section components stay clean.
interface Props {
  name:
    | "lock"
    | "bolt"
    | "chip"
    | "at"
    | "layers"
    | "clock"
    | "arrow"
    | "download"
    | "github";
}
const { name } = Astro.props;
---

{name === "lock" && (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
    <rect x="5" y="11" width="14" height="9" rx="2"></rect>
    <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
  </svg>
)}

{name === "bolt" && (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
    <path d="m13 3-7 11h5l-1 7 7-11h-5l1-7Z" stroke-linejoin="round"></path>
  </svg>
)}

{name === "chip" && (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
    <rect x="6" y="6" width="12" height="12" rx="1"></rect>
    <path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"></path>
  </svg>
)}

{name === "at" && (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
    <circle cx="12" cy="12" r="3"></circle>
    <path d="M15 12v1.5a2.5 2.5 0 0 0 5 0V12a8 8 0 1 0-3.2 6.4"></path>
  </svg>
)}

{name === "layers" && (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
    <path d="m12 4 8 4-8 4-8-4 8-4Z"></path>
    <path d="m4 12 8 4 8-4M4 16l8 4 8-4"></path>
  </svg>
)}

{name === "clock" && (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
    <circle cx="12" cy="12" r="9"></circle>
    <path d="M12 7v5l3 2"></path>
  </svg>
)}

{name === "arrow" && (
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6">
    <path d="M3 7h8M7 3l4 4-4 4"></path>
  </svg>
)}

{name === "download" && (
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6">
    <path d="M7 2v8M3 7l4 3 4-3M2 12h10"></path>
  </svg>
)}

{name === "github" && (
  <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
  </svg>
)}
